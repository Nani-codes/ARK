# Strapi server URL (local)
HOST=0.0.0.0
PORT=1337

# App secrets — generate your own for production
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Razorpay — get from https://dashboard.razorpay.com/app/keys
# REQUIRED for real online payments. Without these, checkout uses a dev mock dialog.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Twilio WhatsApp — transactional notifications (OTP, orders, quotes, returns)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Approved WhatsApp template ContentSids (HX...)
# Optional — defaults loaded from src/config/twilio-template-sids.json
# Run: npx tsx scripts/sync-twilio-templates.ts --create
TWILIO_TEMPLATE_OTP=HX229f5a04fd0510ce1b071852155d3e75
TWILIO_TEMPLATE_ORDER_PLACED=
TWILIO_TEMPLATE_ORDER_CONFIRMED=
TWILIO_TEMPLATE_ORDER_OUT_FOR_DELIVERY=
TWILIO_TEMPLATE_ORDER_DELIVERED=
TWILIO_TEMPLATE_ORDER_CANCELLED=
TWILIO_TEMPLATE_QUOTE_RECEIVED=
TWILIO_TEMPLATE_QUOTE_CONTACTED=
TWILIO_TEMPLATE_QUOTE_QUOTED=
TWILIO_TEMPLATE_QUOTE_CLOSED=
TWILIO_TEMPLATE_RETURN_RECEIVED=
TWILIO_TEMPLATE_RETURN_APPROVED=
TWILIO_TEMPLATE_RETURN_REJECTED=
TWILIO_TEMPLATE_RETURN_COMPLETED=

# Set to true to log notifications without sending (dev)
NOTIFICATIONS_DISABLED=false

# Push notifications — set to true to log only (no Expo Push API calls)
PUSH_NOTIFICATIONS_DISABLED=false
