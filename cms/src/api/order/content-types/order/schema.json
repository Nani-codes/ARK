{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "orderNumber": {
      "type": "string",
      "unique": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "out_for_delivery", "delivered"],
      "default": "pending",
      "required": true
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["neft", "cod"],
      "default": "cod",
      "required": true
    },
    "deliveryAddress": {
      "type": "text",
      "required": true
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "order.order-item"
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "taxes": {
      "type": "decimal",
      "required": true
    },
    "total": {
      "type": "decimal",
      "required": true
    }
  }
}
