{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "orderNumber": {
      "type": "string",
      "unique": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "out_for_delivery", "delivered", "cancelled"],
      "default": "pending",
      "required": true
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["neft", "cod", "online"],
      "default": "cod",
      "required": true
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": ["pending", "paid", "failed", "refunded"],
      "default": "pending"
    },
    "razorpayPaymentId": {
      "type": "string"
    },
    "razorpayOrderId": {
      "type": "string"
    },
    "deliveryFee": {
      "type": "decimal",
      "default": 0
    },
    "deliverySlot": {
      "type": "enumeration",
      "enum": ["asap", "two_hour", "next_day"],
      "default": "asap"
    },
    "estimatedDeliveryAt": {
      "type": "datetime"
    },
    "cancelUntil": {
      "type": "datetime"
    },
    "pincode": {
      "type": "string"
    },
    "gstin": {
      "type": "string"
    },
    "businessName": {
      "type": "string"
    },
    "assignedTo": {
      "type": "string"
    },
    "deliveryAddress": {
      "type": "text",
      "required": true
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "order.order-item"
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "taxes": {
      "type": "decimal",
      "required": true
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "internalNotes": {
      "type": "text"
    },
    "neftProofUrl": {
      "type": "string"
    }
  }
}
