{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Construction material product"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "compareAtPrice": {
      "type": "decimal"
    },
    "unit": {
      "type": "string",
      "required": true,
      "default": "Piece"
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "inStock": {
      "type": "boolean",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "variantOptionName": {
      "type": "string",
      "default": "Size"
    },
    "variants": {
      "type": "component",
      "repeatable": true,
      "component": "product.product-variant"
    },
    "specs": {
      "type": "component",
      "repeatable": true,
      "component": "product.product-spec"
    },
    "variantAxes": {
      "type": "component",
      "repeatable": true,
      "component": "product.variant-axis"
    },
    "variantCombinations": {
      "type": "component",
      "repeatable": true,
      "component": "product.variant-combination"
    },
    "replacementDays": {
      "type": "integer",
      "default": 7,
      "min": 0
    },
    "bulkPricingEnabled": {
      "type": "boolean",
      "default": false
    },
    "brand": {
      "type": "string"
    },
    "tags": {
      "type": "json"
    },
    "onDeal": {
      "type": "boolean",
      "default": false
    },
    "dealPrice": {
      "type": "decimal"
    },
    "bestSeller": {
      "type": "boolean",
      "default": false
    },
    "authenticityVerified": {
      "type": "boolean",
      "default": false
    },
    "priceUnitLabel": {
      "type": "string"
    }
  }
}
