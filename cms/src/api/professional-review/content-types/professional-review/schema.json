{
  "kind": "collectionType",
  "collectionName": "professional_reviews",
  "info": {
    "singularName": "professional-review",
    "pluralName": "professional-reviews",
    "displayName": "Professional Review",
    "description": "Customer reviews for professionals"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "professional": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::professional-profile.professional-profile",
      "inversedBy": "reviews"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "comment": {
      "type": "text"
    }
  }
}
