{
  "kind": "collectionType",
  "collectionName": "specialties",
  "info": {
    "singularName": "specialty",
    "pluralName": "specialties",
    "displayName": "Specialty",
    "description": "Professional trade specialties"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "trade": {
      "type": "enumeration",
      "enum": [
        "contractor",
        "architect",
        "interior_designer",
        "electrician",
        "plumber",
        "painter",
        "other"
      ]
    },
    "professionals": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::professional-profile.professional-profile",
      "mappedBy": "specialties"
    }
  }
}
