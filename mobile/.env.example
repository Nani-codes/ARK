# Strapi API base URL — pick ONE for your setup:
#
# Physical device / Expo Go on phone (same Wi‑Fi as your Mac):
#   EXPO_PUBLIC_STRAPI_URL=http://YOUR_LAN_IP:1337
#   Find LAN IP: ipconfig getifaddr en0
#
# iOS Simulator (on this Mac):
#   EXPO_PUBLIC_STRAPI_URL=http://localhost:1337
#
# Android Emulator:
#   EXPO_PUBLIC_STRAPI_URL=http://10.0.2.2:1337
#
EXPO_PUBLIC_STRAPI_URL=http://192.168.1.4:1337

# EAS (optional — set after `npm run eas:init`)
# EAS_PROJECT_ID=your-project-uuid

# Build installable APK (not AAB):
#   cd mobile && npm run eas:build:apk
# Download from https://expo.dev/accounts/nani1/projects/ark-procurement
#
# Razorpay (server-side — set on Strapi / ark.trilolabs.com, NOT in this file):
#   RAZORPAY_KEY_ID=rzp_test_...
#   RAZORPAY_KEY_SECRET=...
# Copy cms/.env.example to cms/.env and add keys there, then restart Strapi.
# Without CMS keys, checkout shows a test/simulate payment dialog.
